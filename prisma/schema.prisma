generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
}

enum TransactionType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
  STOCK_OPNAME
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STOCK_IN
  STOCK_OUT
  STOCK_ADJUSTMENT
  STOCK_OPNAME
}

model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  email        String?  @unique
  passwordHash String
  role         UserRole @default(OPERATOR)
  permissions  String[] @default([])
  isDeleted    Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions Transaction[]
  auditLogs    AuditLog[]
  stockOpnameSessions StockOpnameSession[]

  @@index([role])
}

model Outsole {
  id             String   @id @default(uuid())

  qrCode         String   @unique

  model          String
  article        String   @default("-")
  color          String
  size           String

  poNumber       String   @default("-")
  bottomTreatment String  @default("None")
  notes          String?
  
  stock          Int      @default(0)

  minimumStock   Int      @default(5)

  isActive       Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions   Transaction[]

  stockOpnameItems StockOpnameItem[]

  @@unique([model, article, color, size, poNumber, bottomTreatment])

  @@index([model])
  @@index([color])
  @@index([size])
  @@index([stock])
}

model Transaction {
  id          String @id @default(uuid())

  outsoleId   String
  outsole     Outsole @relation(fields: [outsoleId], references: [id])

  userId      String
  user        User @relation(fields: [userId], references: [id])

  type        TransactionType

  qty         Int

  notes       String?

  createdAt   DateTime @default(now())

  @@index([outsoleId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model AuditLog {
  id            String @id @default(uuid())

  userId        String
  user          User @relation(fields: [userId], references: [id])

  action        AuditAction

  entityName    String

  entityId      String

  beforeData    Json?

  afterData     Json?

  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([entityName])
  @@index([entityId])
  @@index([createdAt])
}

model StockOpnameSession {
  id              String @id @default(uuid())

  sessionName     String

  createdById     String
  createdBy       User @relation(fields: [createdById], references: [id])

  startedAt       DateTime @default(now())

  finishedAt      DateTime?

  items           StockOpnameItem[]

  createdAt       DateTime @default(now())

  @@index([startedAt])
}

model StockOpnameItem {
  id                 String @id @default(uuid())

  sessionId          String
  session            StockOpnameSession @relation(fields: [sessionId], references: [id])

  outsoleId          String
  outsole            Outsole @relation(fields: [outsoleId], references: [id])

  systemStock        Int

  physicalStock      Int

  difference         Int

  createdAt          DateTime @default(now())

  @@index([sessionId])
  @@index([outsoleId])
}

model ShoeModel {
  id          String        @id @default(cuid())
  name        String        @unique // e.g., "LITE RACER ADAPT 8.0 I WIDE"
  lastUpdated DateTime      @default(now())
  toolingItems ToolingItem[]
}

model ToolingItem {
  id          String        @id @default(cuid())
  modelId     String
  model       ShoeModel     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  category    String        // "BOTTOM TOOLING" or "ASSEMBLY TOOLING"
  name        String        // e.g., "Gauge top net", "3D Gauge"
  remark      String?       // e.g., "DRAWING PROCESS"
  phases      ToolingPhase[]

  @@index([modelId])
  @@unique([modelId, name])
}

model ToolingPhase {
  id          String        @id @default(cuid())
  itemId      String
  item        ToolingItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  phaseType   String        // "SAMPLE", "EXTREME", or "FSR"
  qty         String?       // e.g., "1 SET", "3 PRS"
  orderDate   DateTime?
  targetETA   DateTime?
  actualETA   DateTime?
  status      String        // "VERIFIED", "EXISTING", "ON PROCESS", "NOT USE"

  @@index([itemId])
  @@unique([itemId, phaseType])
}

model BpmTfmStock {
  id        String   @id @default(cuid())
  codeLast  String
  toolName  String
  type      String   @default("")
  size      String
  devStock  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([codeLast, toolName, type, size])
  @@index([codeLast])
}

model Handover {
  id          String   @id @default(cuid())
  date        DateTime
  recipient   String
  giver       String   @default("SYSTEM") // Can be extended to relation with User
  modelName   String?
  codeLast    String?
  
  items       HandoverItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HandoverItem {
  id          String   @id @default(cuid())
  handoverId  String
  handover    Handover @relation(fields: [handoverId], references: [id], onDelete: Cascade)
  
  toolName    String
  type        String   @default("")
  size        String
  satuan      String   @default("SET")
  qty         Int
  remark      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([handoverId])
}

// ============================================================
// ISOLATED MODULE: Purchase Tracking (Tracking Pembelian)
// NO RELATION to core inventory tables. Acts as an independent
// informational ledger for purchase order status tracking.
// ============================================================
model PurchaseTracking {
  id               String    @id @default(cuid())
  batchId          String    // Groups multiple sizes submitted in one matrix
  article          String    // e.g., HQ0170, ID9156
  modelName        String    // e.g., VL COURT 3.0 (populated from ShoeModel)
  genderCategory   String    // e.g., "Men", "Women", "Kids"
  midsoleMaterial  String?   // Midsole material spec
  outsoleMaterial  String?   // Outsole material spec
  midsoleColor     String?   // Midsole color
  outsoleColor     String?   // Outsole color
  bottomTreatment  String?   // "Spray", "Marble", "Spackle"
  imageUrl         String?   // Base64 image data or URL string
  size             String    // e.g., "42", "8T"
  quantity         Int       @default(0) // Quantity for this specific size
  isOrdered        Boolean   @default(false)
  poNumber         String?   // PO Number (if ordered)
  supplier         String?   // Vendor name
  etaDate          DateTime?
  notes            String?   // Free-form notes
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([batchId])
  @@index([article])
  @@index([modelName])
  @@index([isOrdered])
}
